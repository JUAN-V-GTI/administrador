{
  "name": "vox-assistant",
  "version": "1.0.0",
  "description": "Asistente de voz personal con widget, noticias y recordatorios",
  "main": "backend/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run react\" \"npm run electron:wait\"",
    "react": "cd frontend && npm start",
    "electron:wait": "wait-on http://localhost:3000 && electron .",
    "build": "cd frontend && npm run build && electron-builder"
  },
  "keywords": [],
  "author": "Tu Nombre",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "1.0.0-rc.12",
    "node-cron": "^3.0.3"
  },
  "build": {
    "appId": "com.tuapp.voxassistant",
    "productName": "VoxAssistant",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "backend/**/*",
      "frontend/build/**/*",
      "python/**/*",
      "config/**/*"
    ]
  }
}
